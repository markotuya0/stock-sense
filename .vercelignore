# Vercel Ignore File
# Files and directories to exclude from deployment

# Development files
node_modules
.env
.env.local
.env.*.local

# Build artifacts (will be rebuilt)
dist
.vite

# Documentation (not needed in production)
*.md
!README.md

# Git
.git
.gitignore

# IDE
.vscode
.idea
*.swp
*.swo

# Logs
logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Testing
coverage
.nyc_output

# Misc
.DS_Store
Thumbs.db