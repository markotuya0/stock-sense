# --- App Config ---
APP_NAME="StockSense AI"
ENVIRONMENT="development"
DEBUG=True

# --- Security ---
# Generate with: python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY="your-super-secret-key-at-least-64-chars"
# Backend URL (for CORS)
FRONTEND_URL="http://localhost:5173"

# --- Database (Supabase / Postgres) ---
# Format: postgresql://[user]:[password]@[host]:[port]/[db_name]
DATABASE_URL="postgresql://postgres:password@localhost:5432/stocksense"

# --- Cache (Upstash Redis) ---
UPSTASH_REDIS_REST_URL=""
UPSTASH_REDIS_REST_TOKEN=""

# --- AI Agents (KEYS REQUIRED) ---
# Get from https://console.groq.com/
GROQ_API_KEY=""
# Get from https://aistudio.google.com/
GOOGLE_API_KEY=""

# --- Payments (Paystack) ---
# Get from https://dashboard.paystack.com/ (Test keys for local)
PAYSTACK_SECRET_KEY="sk_test_..."
PAYSTACK_PUBLIC_KEY="pk_test_..."

# --- Notifications (Telegram) ---
# Get from @BotFather
TELEGRAM_BOT_TOKEN=""
TELEGRAM_PERSONAL_CHAT_ID=""
