# Stock Sense Environment Configuration
# Copy this file to .env and update with your actual values

# Application
DEBUG=True
LOG_LEVEL=INFO
API_PORT=8000
SECRET_KEY=your-secret-key-here

# Database
DATABASE_URL=sqlite:///stock.db
# For PostgreSQL: postgresql://user:password@localhost:5432/stock_sense

# Market Data
MARKET_DATA_API_KEY=your-api-key-here
MARKET_DATA_PROVIDER=finnhub  # Options: finnhub, alpha_vantage, yfinance

# Email (for alerts)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password

# AI/Agent Configuration
OPENAI_API_KEY=your-openai-api-key
AGENT_MODEL=gpt-4

# Monitoring & Logging
LOG_FILE=stock_sense.log
SENTRY_DSN=

# Feature Flags
ENABLE_ALERTS=True
ENABLE_AI_ANALYSIS=True
ENABLE_PERFORMANCE_TRACKING=True

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW=3600

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:8000

# Cache
CACHE_TTL=3600
CACHE_TYPE=simple  # Options: simple, redis

# Timezone
TIMEZONE=UTC
