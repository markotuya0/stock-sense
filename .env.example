# Application
ENVIRONMENT=development
DEBUG=True
LOG_LEVEL=INFO
SECRET_KEY=generate-a-secure-secret-key-here

# Database
# For Supabase PostgreSQL
DATABASE_URL=postgresql://postgres:password@db.xxxxxx.supabase.co:5432/postgres

# Cache (Upstash Redis)
UPSTASH_REDIS_REST_URL=https://xxxxxx.upstash.io
UPSTASH_REDIS_REST_TOKEN=your-token-here

# AI APIs
GROQ_API_KEY=gsk_xxxxxx
GOOGLE_API_KEY=AIzaSyxxxxxx

# Telegram
TELEGRAM_BOT_TOKEN=123456:ABC-DEF
TELEGRAM_PERSONAL_CHAT_ID=your-chat-id-here

# Budget Guards
BUDGET_PER_USER_DAILY_USD=0.05
BUDGET_PLATFORM_DAILY_USD=10.0
